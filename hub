-- ── Helpers ──
local function splitCSV(s)
    local t = {}
    if not s or s == "" then return t end
    for p in (s..","):gmatch("([^,]*),") do
        local tr = p:match("^%s*(.-)%s*$")
        if tr ~= "" then table.insert(t, tr) end
    end
    return t
end
local function fmt(n)
    if not n or n <= 0 then return "$0" end
    local s,out,len = tostring(math.floor(n)),"",#tostring(math.floor(n))
    for i=1,len do if i>1 and (len-i+1)%3==0 then out=out.."," end out=out..s:sub(i,i) end
    return "$"..out
end
