local function buildFruitList(items)
    for _, c in ipairs(fScroll:GetChildren()) do if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end end
    local tv,rc=0,0; for _,it in ipairs(items) do tv=tv+it.value; if it.value>0 then rc=rc+1 end end
    stLbl.Text=string.format("📦 %d  ✅ %d  💰 %s",#items,rc,fmt(tv))
    for i, item in ipairs(items) do
        local pdata=PLANT_DATA[item.plantType]; local rarity=pdata and pdata.Rarity or "Common"
        local rarCol=RARITY_COLORS[rarity] or Color3.fromRGB(160,160,160); local stgCol=STAGE_COLORS[item.stage] or Color3.fromRGB(160,160,160)
        local hasMut=item.mutation~=""; local hasVar=item.variant~=""; local rowH=hasMut and 76 or 58
        local row=mkBtn(fScroll,nil,nil,"",12,C.white,i%2==0 and Color3.fromRGB(20,26,38) or Color3.fromRGB(15,19,30))
        row.Name="Row_"..i; row.Size=UDim2.new(1,0,0,rowH); row.LayoutOrder=i
        corner(row,7); local rs=Instance.new("UIStroke",row); rs.Color=Color3.fromRGB(26,34,50); rs.Thickness=1
        local acc=mkFrame(row,UDim2.new(0,4,0,5),UDim2.new(0,3,1,-10),rarCol); corner(acc,2)
        mkLabel(row,UDim2.new(0,10,0,5),UDim2.new(0,24,0,14),"#"..i,10,Enum.Font.GothamBold,Color3.fromRGB(65,96,65))
        local prefix=(item.isGiant and "⚡" or "")..(item.isPlant and "🌿 " or "🍎 ")
        mkLabel(row,UDim2.new(0,36,0,4),UDim2.new(0,160,0,18),prefix..item.plantType,13,Enum.Font.GothamBold,Color3.fromRGB(195,255,195))
        local vLbl=mkLabel(row,UDim2.new(1,-152,0,4),UDim2.new(0,148,0,18),item.value>0 and fmt(item.value) or "⏳ Growing",13,Enum.Font.GothamBold,item.value>0 and Color3.fromRGB(0,255,110) or Color3.fromRGB(110,110,110),Enum.TextXAlignment.Right)
        mkLabel(row,UDim2.new(0,36,0,23),UDim2.new(0,78,0,12),rarity,9,Enum.Font.GothamBold,rarCol)
        mkLabel(row,UDim2.new(1,-152,0,23),UDim2.new(0,108,0,12),string.format("⚖ %.4f kg",item.weight),9,Enum.Font.Gotham,Color3.fromRGB(0,185,230),Enum.TextXAlignment.Right)
        mkLabel(row,UDim2.new(0,36,0,37),UDim2.new(0,138,0,12),string.format("🌱 %s ×%.2f",item.stage,item.ripe),9,Enum.Font.GothamBold,stgCol)
        local bW=item.isPlant and (pdata and pdata.PlantBaseWeight or 1) or (pdata and pdata.FruitBaseWeight or 1)
        local mStr=string.format("×%.2f scale",bW>0 and item.weight/bW or 0)..(hasVar and string.format(" ×%.1f var",item.varMult) or "")..(hasMut and string.format(" ×%.2f mut",item.mutMult) or "")
        local multL=mkLabel(row,UDim2.new(1,-152,0,37),UDim2.new(0,148,0,12),mStr,8,Enum.Font.Gotham,Color3.fromRGB(96,175,96),Enum.TextXAlignment.Right); multL.TextTruncate=Enum.TextTruncate.AtEnd
        if hasVar then
            local vc=VARIANT_COLORS[item.variant] or Color3.fromRGB(200,200,200)
            local vb=mkFrame(row,UDim2.new(0,118,0,38),UDim2.new(0,50,0,13),vc); vb.BackgroundTransparency=0.70; corner(vb,4)
            mkLabel(vb,UDim2.new(0,0,0,0),UDim2.new(1,0,1,0),"✨ "..item.variant,8,Enum.Font.GothamBold,vc,Enum.TextXAlignment.Center)
        end
        if hasMut then
            local xo,yp=36,rowH-19
            for _, mName in ipairs(item.mutList) do
                local md=MUTATION_DATA[mName]; local mult=md and md.priceMultiplier or 1
                local mc=MUTATION_COLORS[mName] or Color3.fromRGB(255,80,80); local cw=math.max(46,#mName*6+18)
                if xo+cw>PW-18 then break end
                local chip=mkFrame(row,UDim2.new(0,xo,0,yp),UDim2.new(0,cw,0,14),mc); chip.BackgroundTransparency=0.72; corner(chip,4)
                mkLabel(chip,UDim2.new(0,0,0,0),UDim2.new(1,0,1,0),mName.." ×"..tostring(mult),8,Enum.Font.GothamBold,mc,Enum.TextXAlignment.Center)
                xo=xo+cw+3
            end
        end
        local cm,cr,ci=item.model,row,i
        row.MouseButton1Click:Connect(function()
            for _, r in ipairs(fScroll:GetChildren()) do if r:IsA("TextButton") then local idx=tonumber(r.Name:match("Row_(%d+)")); if idx then r.BackgroundColor3=idx%2==0 and Color3.fromRGB(20,26,38) or Color3.fromRGB(15,19,30); local st=r:FindFirstChildWhichIsA("UIStroke"); if st then st.Color=Color3.fromRGB(26,34,50); st.Thickness=1 end end end end
            cr.BackgroundColor3=Color3.fromRGB(0,40,22); local sel=cr:FindFirstChildWhichIsA("UIStroke"); if sel then sel.Color=Color3.fromRGB(0,205,90); sel.Thickness=2 end
            if cm and cm.Parent then highlightModel(cm) end
            pcall(function() local cf; if cm:IsA("Model") then local ok2,mc2=pcall(function() return cm:GetModelCFrame() end); if ok2 then cf=mc2 end elseif cm:IsA("BasePart") then cf=cm.CFrame end; if cf then workspace.CurrentCamera.CFrame=CFrame.new(cf.Position+Vector3.new(0,5,10),cf.Position) end end)
        end)
    end
end

