local function collectData()
    local items = {}
    if not container then return items end
    for _, plant in ipairs(container:GetChildren()) do
        if plant:IsA("Model") then
            local pType=plant:GetAttribute("PlantType") or ""; local isGiant=plant:GetAttribute("IsGiant") or false; local fruitFound=false
            for _, child in ipairs(plant:GetChildren()) do
                if child:IsA("Model") and child.Name:find("Fruit") then
                    fruitFound=true
                    if child:GetAttribute("FullyGrown")==true then
                        local fw=child:GetAttribute("FruitWeight") or 0; local mut=child:GetAttribute("Mutation") or ""; local var=child:GetAttribute("Variant") or ""; local stage=child:GetAttribute("RipenessStage") or ""; local ripe=child:GetAttribute("RipenessMultiplier") or 1
                        local val=calcValue(pType,fw,mut,var,ripe,false); local mutList=splitCSV(mut)
                        local mutMult=1; if #mutList>0 then local s=0; for _,m in ipairs(mutList) do local md=MUTATION_DATA[m]; if md then s=s+(md.priceMultiplier or 1) end end; mutMult=s-#mutList+1; if mutMult<1 then mutMult=1 end end
                        local varMult=1; if var~="" then local vd=VARIANT_DATA[var]; if vd then varMult=vd.priceMultiplier or 1 end end
                        table.insert(items,{model=child,plantType=pType,weight=fw,value=val,mutation=mut,mutList=mutList,mutMult=mutMult,variant=var,varMult=varMult,stage=stage,ripe=ripe,isGiant=isGiant,isPlant=false})
                    end
                end
            end
            if not fruitFound then
                local pw=plant:GetAttribute("PlantWeight")
                if pw and plant:GetAttribute("HarvestablePlant") then
                    local mut=plant:GetAttribute("Mutation") or ""; local var=plant:GetAttribute("Variant") or ""; local stage=plant:GetAttribute("RipenessStage") or ""; local ripe=plant:GetAttribute("RipenessMultiplier") or 1
                    local val=calcValue(pType,pw,mut,var,ripe,true); local mutList=splitCSV(mut)
                    local mutMult=1; if #mutList>0 then local s=0; for _,m in ipairs(mutList) do local md=MUTATION_DATA[m]; if md then s=s+(md.priceMultiplier or 1) end end; mutMult=s-#mutList+1; if mutMult<1 then mutMult=1 end end
                    local varMult=1; if var~="" then local vd=VARIANT_DATA[var]; if vd then varMult=vd.priceMultiplier or 1 end end
                    table.insert(items,{model=plant,plantType=pType,weight=pw,value=val,mutation=mut,mutList=mutList,mutMult=mutMult,variant=var,varMult=varMult,stage=stage,ripe=ripe,isGiant=isGiant,isPlant=true})
                end
            end
        end
    end
    table.sort(items, function(a,b) return a.value>b.value end)
    return items
end

