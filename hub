local function calcValue(plantType, weight, mutStr, varStr, ripe, isPlant)
    local pdata = PLANT_DATA[plantType]
    if not pdata then return 0 end
    local baseV = isPlant and (pdata.PlantBaseValue or 0) or (pdata.FruitBaseValue or 0)
    local baseW = isPlant and (pdata.PlantBaseWeight or 1) or (pdata.FruitBaseWeight or 1)
    if baseV==0 or baseW==0 then return 0 end
    local scale = weight/baseW
    local r = (ripe and ripe>0) and ripe or 1
    local mutList = splitCSV(mutStr)
    local mutMult = 1
    if #mutList > 0 then
        local s = 0
        for _, m in ipairs(mutList) do local md=MUTATION_DATA[m]; if md and md.priceMultiplier then s=s+md.priceMultiplier end end
        mutMult = s - #mutList + 1; if mutMult < 1 then mutMult = 1 end
    end
    local varMult = 1
    if varStr and varStr~="" then local vd=VARIANT_DATA[varStr]; if vd and vd.priceMultiplier then varMult=vd.priceMultiplier end end
    return math.floor(baseV * scale * scale * r * varMult * mutMult)
end

