-- AUTOBUY LOGIC — single trip for both shops
-- ════════════════════════════════════════
local function tpTo(pos) local hrp=getHRP(); if hrp then hrp.CFrame=CFrame.new(pos) end end

local function buyShop(shopId, shopKey, shopPos)
    local ok, data = pcall(function() return GetShopData:InvokeServer(shopId) end)
    if not ok or not data or not data.Items then return 0 end
    local items = shopKey=="seed" and SEED_ITEMS or GEAR_ITEMS
    local toBuy = {}
    for _, name in pairs(items) do
        if abState[shopKey].selected[name] then
            local e = data.Items[name]; if e and e.Amount and e.Amount>0 then table.insert(toBuy, name) end
        end
    end
    if #toBuy == 0 then return 0 end

    tpTo(shopPos); wait(0.3)
    local bought = 0
    for _, name in pairs(toBuy) do
        if not abState[shopKey].enabled then break end
        local available = (data.Items[name] and data.Items[name].Amount) or 0
        local maxBuys = abState[shopKey].buyAll and available or 1
        for i = 1, maxBuys do
            if not abState[shopKey].enabled then break end
            setStatus("Buying "..name.." "..i.."/"..maxBuys, C.orange)
            local pok, result = pcall(function() return PurchaseShopItem:InvokeServer(shopId, name) end)
            if pok and result then
                bought = bought + 1
                if type(result)=="table" and result.Items then
                    data = result
                    local rem = data.Items[name] and data.Items[name].Amount or 0
                    if rem <= 0 then break end
                end
            else break end
            wait(0.07)
        end
    end
    return bought
end

-- ONE shared loop — saves pos once, visits enabled shops, TPs back once
local loopRunning = false
local function startLoop()
    if loopRunning then return end
    loopRunning = true
    spawn(function()
        while abState.seed.enabled or abState.gear.enabled do
            if not isBuying then
                -- check if anything to buy before TP
                local seedHasStock, gearHasStock = false, false
                if abState.seed.enabled then
                    local ok, d = pcall(function() return GetShopData:InvokeServer("SeedShop") end)
                    if ok and d and d.Items then
                        for _, name in pairs(SEED_ITEMS) do
                            if abState.seed.selected[name] then
                                local e = d.Items[name]; if e and e.Amount and e.Amount>0 then seedHasStock=true; break end
                            end
                        end
                    end
                end
                if abState.gear.enabled then
                    local ok, d = pcall(function() return GetShopData:InvokeServer("GearShop") end)
                    if ok and d and d.Items then
                        for _, name in pairs(GEAR_ITEMS) do
                            if abState.gear.selected[name] then
                                local e = d.Items[name]; if e and e.Amount and e.Amount>0 then gearHasStock=true; break end
                            end
                        end
                    end
                end

                if seedHasStock or gearHasStock then
                    isBuying = true
                    local savedPos = getHRP().CFrame.Position
                    local total = 0
                    if seedHasStock then total = total + buyShop("SeedShop","seed",SEED_POS) end
                    if gearHasStock then total = total + buyShop("GearShop","gear",GEAR_POS) end
                    tpTo(savedPos)
                    if total > 0 then setStatus("Bought x"..total.." — back!", C.green)
                    else setStatus("Nothing bought — back", C.dim) end
                    isBuying = false
                else
                    setStatus("Watching stock...", C.dim)
                end
            end
            wait(1)
        end
        loopRunning = false
        if not abState.seed.enabled and not abState.gear.enabled then setStatus("Stopped", C.dim) end
    end)
end

ShopRestocked.OnClientEvent:Connect(function(shopId)
    local shopKey = (shopId=="SeedShop") and "seed" or "gear"
    if abState[shopKey].enabled and not isBuying then
        setStatus("Restock detected!", C.orange)
        -- loop will pick it up on next 1s tick automatically
    end
end)

